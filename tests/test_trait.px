trait Named {
    func name(&self) -> str;
}

struct Person { id: int, first_name: str }
impl Named for Person {
    func name(&self) -> str {
        return self.first_name;
    }
}

func greet(n: Named) {
    say("Hello, ${n.name()}!");
}

auto p = Person { id: 1, first_name: "Plix" };
greet(p);

